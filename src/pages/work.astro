---
import Base from '../layouts/Base.astro';
import Terminal from '../components/Terminal.astro';
import Cta from '../components/Cta.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';

const title = '1Lime — Work';
const description = 'Proof you can measure: the standards every 1Lime site clears. Case studies land here as projects ship.';

// Honesty rule (content-model.md §ProofPoint): qualitative claims only until E measures THIS site.
const checks = [
  { ok: true, key: 'a11y     ', val: 'WCAG 2.1 AA — target on every page' },
  { ok: true, key: 'perf     ', val: 'static · CDN · no JS runtime shipped' },
  { ok: true, key: 'resilient', val: 'renders with JavaScript disabled' },
  { ok: true, key: 'portable ', val: 'plain Astro · GitHub Pages · zero lock-in' },
  { ok: false, key: 'metrics  ', val: 'awaiting first measured deploy — no invented numbers' },
];

const hud = [
  { b: 'AA', s: 'accessibility target' },
  { b: 'STATIC', s: 'no server to fall over' },
  { b: 'NO-JS', s: 'content + links survive' },
  { b: 'DAYS', s: 'discovery → deploy' },
];

const gh = site.github[0];
---
<Base title={title} description={description}>
  <!-- INTRO -->
  <section class="section" aria-labelledby="work-h">
    <div class="container">
      <div class="cy-panel hero">
        <p class="kicker">verify ./site</p>
        <h1 id="work-h" class="glow">Built to standards you can measure</h1>
        <p class="lede">We are early and we say so. No invented metrics here — only the bar every 1Lime
          site is built to clear, shown as the checks run on it.</p>
      </div>
    </div>
  </section>

  <!-- VERIFY TERMINAL (show, don't tell) -->
  <section class="section" aria-labelledby="proof-h">
    <div class="container">
      <p class="kicker">$ 1lime verify</p>
      <h2 id="proof-h">The bar, on every page</h2>
      <Terminal title="1lime verify ./site" label="Standards every 1Lime site is built to clear">
        <ul class="term__body">
          {checks.map((c) => (
            <li class="termline">
              <span class={`tag ${c.ok ? 'tag--ok' : 'tag--wait'}`} aria-hidden="true">{c.ok ? '[✓]' : '[ ]'}</span>
              <span><strong>{c.key}</strong> {c.val}</span>
            </li>
          ))}
        </ul>
      </Terminal>
    </div>
  </section>

  <!-- HUD TILES -->
  <section class="section" aria-labelledby="hud-h">
    <div class="container">
      <div class="cy-panel">
        <div class="pad">
          <p class="kicker">readout</p>
          <h2 id="hud-h">Non-negotiables</h2>
          <ul class="hud" role="list">
            {hud.map((t) => (
              <li class="hud__tile"><b aria-hidden="true">{t.b}</b><span>{t.s}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CASE STUDIES (empty-but-honest, shown as `ls`) -->
  <section class="section" aria-labelledby="cases-h">
    <div class="container">
      <p class="kicker">ls ./work</p>
      <h2 id="cases-h">Case studies</h2>
      <Terminal title="ls ./work" label="Published case studies">
        <ul class="term__body">
          <li class="termline"><span class="tag tag--wait" aria-hidden="true">»</span><span class="muted">total 0 — no published case studies yet</span></li>
          <li class="termline"><span class="tag tag--wait" aria-hidden="true">»</span><span class="muted">each shipped project lands here with goal, build, and measured results</span></li>
          <li class="termline"><span class="tag tag--ok" aria-hidden="true">→</span><span>read the source meanwhile: <a class="ghlink" href={gh.url} rel="noopener"><Icon name="github" />{gh.handle}</a></span></li>
        </ul>
      </Terminal>
    </div>
  </section>

  <Cta id="contact" headline="want to be the first case study?" body="Early projects get the most attention. Bring it to the Discord and let's build something worth writing up." />

  <style>
    .hero { padding: var(--s-4); }
    .pad { padding: var(--s-4); }
    .lede { font-size: var(--step-1); color: var(--cy-dim); max-width: 54ch; }
    .ghlink { display: inline-flex; align-items: center; gap: 0.4rem; }
  </style>
</Base>
