---
import Base from '../layouts/Base.astro';
import Terminal from '../components/Terminal.astro';
import Cta from '../components/Cta.astro';

const title = '1Lime — About';
const description = 'The factory is the product. 1Lime is a multi-agent system turning business requirements into fast, accessible websites — sharper every project.';

// Show, don't tell: principles rendered as a config file.
const rules = [
  { k: 'build', v: '"systems, not projects"', c: 'reusable parts → next build starts ahead' },
  { k: 'gates', v: 'required = true', c: 'a11y + perf are gates, not nice-to-haves' },
  { k: 'proof', v: 'fabricated = false', c: 'a number ships only once measured on the real site' },
  { k: 'owner', v: '"you"', c: 'plain portable code, open host, no lock-in' },
];
---
<Base title={title} description={description}>
  <!-- INTRO -->
  <section class="section" aria-labelledby="about-h">
    <div class="container">
      <div class="cy-panel hero">
        <p class="kicker">whoami</p>
        <h1 id="about-h" class="glow">The factory is the product</h1>
        <p class="lede">1Lime isn't a freelancer with a backlog. It's a system: a pipeline that turns what
          your business needs into a production website — and gets sharper every time it runs.</p>
      </div>
    </div>
  </section>

  <!-- WHY (kept short) -->
  <section class="section" aria-labelledby="why-h">
    <div class="container prose">
      <p class="kicker">why</p>
      <h2 id="why-h">Most small-business sites fail slowly</h2>
      <p>They launch, then rot — slow to load, awkward on a phone, impossible to edit, quietly inaccessible
        to part of every audience. The usual fix is a bigger budget. The real problem is that each site is
        rebuilt by hand, with the same mistakes.</p>
      <p>So we built a factory. Discovery, architecture, build, verification, deploy — distinct stages with
        their own checks. Every project leaves reusable components and knowledge behind, which is why the
        work gets faster and more reliable as it scales, not slower.</p>
    </div>
  </section>

  <!-- PRINCIPLES (show: config file) -->
  <section class="section" aria-labelledby="principles-h">
    <div class="container">
      <p class="kicker">cat principles.toml</p>
      <h2 id="principles-h">Rules we don't bend</h2>
      <Terminal title="principles.toml" label="Principles 1Lime holds to">
        <ul class="term__body">
          {rules.map((r) => (
            <li class="termline">
              <span><strong>{r.k}</strong> <span aria-hidden="true">= </span><span class="val">{r.v}</span>  <span class="muted"># {r.c}</span></span>
            </li>
          ))}
        </ul>
      </Terminal>
    </div>
  </section>

  <Cta id="contact" headline="put the factory to work" body="Bring a goal and some content. We turn it into a fast, accessible site — and tell you exactly what that takes." />

  <style>
    .hero { padding: var(--s-4); }
    .lede { font-size: var(--step-1); color: var(--cy-dim); max-width: 54ch; }
    .prose { max-width: 64ch; }
    .val { color: var(--lime); font-family: var(--font-mono); }
  </style>
</Base>
