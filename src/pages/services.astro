---
import Base from '../layouts/Base.astro';
import Step from '../components/Step.astro';
import Terminal from '../components/Terminal.astro';
import Cta from '../components/Cta.astro';

const title = '1Lime — Services';
const description = 'What 1Lime ships: local business sites, landing pages, portfolios. Fast, accessible, static, deployed in days.';

const modules = [
  { id: 'local', badge: '[ READY ]', title: 'Local business sites', body: 'Restaurants, trades, clinics, services. Fast, findable, mobile-first — live in days.' },
  { id: 'landing', badge: '[ READY ]', title: 'Landing pages', body: 'Single-purpose pages built to convert one visitor action. Measured, not guessed.' },
  { id: 'portfolio', badge: '[ READY ]', title: 'Portfolios & brochure sites', body: 'Credible, accessible sites that age well and load instantly.' },
];

const manifest = [
  'semantic, accessible HTML  ·  WCAG 2.1 AA target',
  'static Astro output  ·  CDN-served  ·  no JS runtime shipped',
  'works with JavaScript disabled  ·  JS only enhances',
  'plain portable code  ·  GitHub Pages  ·  zero lock-in',
];

const steps = [
  { n: 1, title: 'Discovery', body: 'We capture goals, audience, and content. You talk; the factory listens.' },
  { n: 2, title: 'Architecture & design', body: 'Sitemap, content model, reusable design system — approved before any build.' },
  { n: 3, title: 'Build & verify', body: 'Astro build, then automated accessibility, performance, and SEO gates. No gate skipped.' },
  { n: 4, title: 'Deploy & improve', body: 'Shipped to a CDN-backed host, then monitored and improved with real data.' },
];
---
<Base title={title} description={description}>
  <!-- INTRO -->
  <section class="section" aria-labelledby="services-h">
    <div class="container">
      <div class="cy-panel hero">
        <p class="kicker">services --list</p>
        <h1 id="services-h" class="glow">What we build</h1>
        <p class="lede">Three modules. Each ships fast, clears the same accessibility and performance bar,
          and is assembled from reusable parts — so the next build starts further ahead.</p>
      </div>
    </div>
  </section>

  <!-- MODULES (show: spec cards) -->
  <section class="section" aria-labelledby="offer-h">
    <div class="container">
      <p class="kicker">modules</p>
      <h2 id="offer-h">Production sites, not experiments</h2>
      <ul class="grid grid--3 reset" role="list">
        {modules.map((m) => (
          <li>
            <article class="module">
              <span class="badge" aria-hidden="true">{m.badge}</span>
              <h3>{m.title}</h3>
              <p class="muted">{m.body}</p>
            </article>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- MANIFEST (show: terminal printout instead of prose) -->
  <section class="section" aria-labelledby="incl-h">
    <div class="container">
      <p class="kicker">cat build.manifest</p>
      <h2 id="incl-h">Every build ships with</h2>
      <Terminal title="build.manifest" label="What every 1Lime build includes">
        <ul class="term__body">
          {manifest.map((line) => (
            <li class="termline"><span class="tag tag--ok" aria-hidden="true">[✓]</span><span>{line}</span></li>
          ))}
        </ul>
      </Terminal>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section" aria-labelledby="process-h">
    <div class="container">
      <div class="cy-panel process">
        <p class="kicker">pipeline --stages</p>
        <h2 id="process-h">A pipeline, every time</h2>
        <ol class="steps">
          {steps.map((s) => <Step n={s.n} title={s.title} body={s.body} />)}
        </ol>
      </div>
    </div>
  </section>

  <Cta id="contact" headline="not sure which module fits?" body="Drop the goal in the Discord. We point you at the right build and what it takes to ship." />

  <style>
    .hero, .process { padding: var(--s-4); }
    .lede { font-size: var(--step-1); color: var(--cy-dim); max-width: 52ch; }
    .reset { list-style: none; padding: 0; margin: 0; }
    .process .steps { list-style: none; margin: 0; padding: 0; max-width: 52rem; }
    .process .step { border-bottom-color: var(--cy-edge); }
    .process .muted { color: var(--cy-dim); }
  </style>
</Base>
