---
import Base from '../layouts/Base.astro';
import Terminal from '../components/Terminal.astro';
import Cta from '../components/Cta.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';

const title = '1Lime — Connect';
const description = 'No forms, no inbox. Message 1Lime on Discord to scope a build, or read the code on GitHub.';

const expect = [
  { k: 'scope', v: 'pages, content, the one action the site should drive' },
  { k: 'quote', v: 'clear price and timeline — no surprise invoices' },
  { k: 'plan ', v: "exactly what you get, when, and what we need from you" },
];
---
<Base title={title} description={description}>
  <!-- CONNECT INTRO -->
  <section class="section" aria-labelledby="contact-h">
    <div class="container">
      <div class="cy-panel hero">
        <p class="kicker">connect</p>
        <h1 id="contact-h" class="glow">Open a channel</h1>
        <p class="lede">No forms, no inbox. Message us on Discord and tell us what to ship — or read the
          code on GitHub first. Both are plain links; neither needs JavaScript.</p>
        <p class="cta-row">
          <a class="btn btn--primary" href={site.discord.invite} rel="noopener"><Icon name="discord" />Message on Discord</a>
        </p>
        <ul class="links" role="list">
          <li>
            <a href={site.discord.invite} rel="noopener"><Icon name="discord" class="links__icon" /><span class="links__url">discord.com/users/…</span></a>
            <span class="muted">— {site.discord.handle}</span>
          </li>
          {site.github.map((g) => (
            <li>
              <a href={g.url} rel="noopener"><Icon name="github" class="links__icon" /><span class="links__url">{g.url.replace('https://', '')}</span></a>
              <span class="muted">— {g.handle}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- WHAT TO EXPECT (show: terminal) -->
  <section class="section" aria-labelledby="expect-h">
    <div class="container">
      <p class="kicker">./call --agenda</p>
      <h2 id="expect-h">What the first chat covers</h2>
      <Terminal title="call --agenda" label="What the first conversation covers">
        <ol class="term__body">
          {expect.map((e) => (
            <li class="termline"><span class="tag tag--ok" aria-hidden="true">→</span><span><strong>{e.k}</strong> {e.v}</span></li>
          ))}
        </ol>
      </Terminal>
    </div>
  </section>

  <Cta headline="ready when you are" body="Bring a goal and some content. We handle the rest — fast, accessible, built to last." />

  <style>
    .hero { padding: var(--s-4); }
    .lede { font-size: var(--step-1); color: var(--cy-dim); max-width: 52ch; }
    .cta-row { display: flex; flex-wrap: wrap; gap: var(--s-2); margin: var(--s-3) 0; }
    .links { list-style: none; padding: 0; margin: var(--s-3) 0 0; display: grid; gap: var(--s-2); }
    .links li { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; }
    .links a { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-mono); word-break: break-all; }
    .links__icon { color: var(--lime); font-size: 1.2em; }
    .links__url { text-decoration: underline; }
  </style>
</Base>
