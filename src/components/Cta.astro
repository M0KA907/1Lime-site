---
// P6/P7 — reusable cyber CTA panel. Discord = primary channel, GitHub = proof. No email.
import { site } from '../data/site';
import Icon from './Icon.astro';
const {
  id,
  headline = 'open a channel',
  body = 'No forms, no inbox. Message us on Discord and tell us what to ship — or read the code first.',
  labelledby = id ? `${id}-h` : undefined,
} = Astro.props;
const gh = site.github[0];
---
<section id={id} class="section" aria-labelledby={labelledby}>
  <div class="container">
    <div class="cy-panel cta">
      <p class="kicker">connect --discord</p>
      <h2 id={labelledby} class="glow">{headline}</h2>
      <p>{body}</p>
      <p class="cta-row">
        <a class="btn btn--primary" href={site.discord.invite} rel="noopener"><Icon name="discord" />Message on Discord</a>
        <a class="btn btn--cyber" href={gh.url} rel="noopener"><Icon name="github" />{gh.handle}</a>
      </p>
      <p class="muted note"><span aria-hidden="true">// </span>both links work with JavaScript disabled — plain anchors, no tracker, no backend.</p>
    </div>
  </div>
</section>
<style>
  .cta { padding: var(--s-4); }
  .cta-row { display: flex; flex-wrap: wrap; gap: var(--s-2); margin-top: var(--s-3); }
  .note { font-size: var(--step--1); margin-top: var(--s-2); margin-bottom: 0; }
  .btn--cyber { font-family: var(--font-mono); border-color: var(--lime); color: #c5f55a; background: color-mix(in srgb, var(--lime) 12%, transparent); }
  .btn--cyber:hover { background: color-mix(in srgb, var(--lime) 24%, transparent); color: #dcfca0; }
</style>
