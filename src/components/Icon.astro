---
// Inline SVG icons — decorative by default (aria-hidden). Brand marks are fill=currentColor
// so they inherit link/button text color. No deps, no network requests.
const { name, class: className = '' } = Astro.props;
---
{name === 'discord' && (
  <svg class={`icon ${className}`} viewBox="0 0 24 24" width="1em" height="1em" aria-hidden="true" focusable="false" fill="currentColor">
    <path d="M20.317 4.369A19.79 19.79 0 0 0 15.432 3c-.21.375-.456.88-.625 1.28a18.27 18.27 0 0 0-5.614 0C9.024 3.88 8.778 3.375 8.568 3A19.74 19.74 0 0 0 3.677 4.37C.533 9.046-.32 13.58.1 18.057a19.9 19.9 0 0 0 6.066 3.058c.488-.665.922-1.372 1.296-2.114a12.9 12.9 0 0 1-2.04-.978c.171-.126.34-.257.5-.39a14.2 14.2 0 0 0 12.155 0c.163.135.331.266.5.39-.65.383-1.336.71-2.043.98.374.74.808 1.448 1.296 2.113a19.84 19.84 0 0 0 6.07-3.058c.5-5.177-.838-9.674-3.524-13.69ZM8.02 15.331c-1.183 0-2.157-1.085-2.157-2.42 0-1.334.955-2.42 2.157-2.42 1.21 0 2.176 1.095 2.157 2.42 0 1.335-.956 2.42-2.157 2.42Zm7.975 0c-1.183 0-2.157-1.085-2.157-2.42 0-1.334.955-2.42 2.157-2.42 1.21 0 2.176 1.095 2.157 2.42 0 1.335-.946 2.42-2.157 2.42Z"/>
  </svg>
)}
{name === 'github' && (
  <svg class={`icon ${className}`} viewBox="0 0 24 24" width="1em" height="1em" aria-hidden="true" focusable="false" fill="currentColor">
    <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.93 0-1.31.467-2.38 1.236-3.22-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.3 1.23A11.5 11.5 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.29-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.91 1.235 3.22 0 4.61-2.807 5.624-5.479 5.92.43.372.823 1.102.823 2.222 0 1.606-.015 2.898-.015 3.293 0 .322.218.694.825.576C20.565 22.092 24 17.595 24 12.297c0-6.627-5.373-12-12-12"/>
  </svg>
)}
{name === 'arrow' && (
  <svg class={`icon ${className}`} viewBox="0 0 24 24" width="1em" height="1em" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M5 12h14M13 6l6 6-6 6"/>
  </svg>
)}
<style>
  .icon { display: inline-block; vertical-align: -0.125em; flex: none; }
</style>
